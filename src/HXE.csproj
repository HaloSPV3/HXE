<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Platform>AnyCPU</Platform>
    <Prefer32Bit>false</Prefer32Bit>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net462;net480;net6.0-windows</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <StartupObject>HXE.Program</StartupObject>
    <AssemblyName>HXE</AssemblyName>
    <RootNamespace>HXE</RootNamespace>
    <!-- Application | Resources -->
    <ApplicationIcon>Assets/icon.ico</ApplicationIcon>
    <!-- Build | General -->
    <Deterministic>true</Deterministic>
    <FileAlignment>512</FileAlignment>
    <Nullable>enable</Nullable>
    <!-- Build | Events -->
    <!-- Ensures GitVersion, SourceLink tasks only run after successful builds -->
    <RunPostBuildEvent>OnBuildSuccess</RunPostBuildEvent>
    <!-- Build | Strong Naming -->

    <TFM_NET6_OR_LATER>$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net6.0'))</TFM_NET6_OR_LATER>

    <!-- Publish -->
    <IsTrimmable>$(TFM_NET6_OR_LATER)</IsTrimmable>
    <!-- Waiting for trim-compatible WPF -->
    <!--<PublishTrimmed>true</PublishTrimmed> -->
    <PublishSingleFile>$(TFM_NET6_OR_LATER)</PublishSingleFile>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == '' AND '$(PublishSingleFile)' == 'true'">win7-x86</RuntimeIdentifier>
    <SelfContained Condition="'$(SelfContained)' == '' AND '$(RuntimeIdentifier)' != ''">true</SelfContained>
    <PublishSingleFile Condition="'$(PublishSingleFile)' == 'true' AND $(RuntimeIdentifier.Contains('win7'))">$([MSBuild]::VersionGreaterThanOrEquals($(NETCoreSdkVersion), '6.0.300'))</PublishSingleFile>
    <!-- Misc -->
    <ProjectGuid>{ACAA5D9F-B23D-43E1-B2DF-8C03230975A1}</ProjectGuid>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <ProductName>HXE</ProductName>
    <PublisherName>Halo SPV3 Team</PublisherName>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <ToolCommandName>hxe</ToolCommandName>
    <UseWPF>true</UseWPF>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <!-- Changing this to "true" will cause a crash when loading any GUI -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <MeziantouPolyfill_ExcludedPolyfills Condition="$(TargetFramework.StartsWith('net4'))">T:System.Runtime.CompilerServices.OverloadResolutionPriorityAttribute</MeziantouPolyfill_ExcludedPolyfills>
  </PropertyGroup>

  <ItemGroup>
    <!-- Mark assemblies with NeutralResourcesLanguageAttribute (CA1824) https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/ca1824
      https://stackoverflow.com/questions/77245575/how-to-set-neutralresourceslanguageattribute-in-my-net-core-project -->
    <AssemblyAttribute Include="System.Resources.NeutralResourcesLanguageAttribute">
      <_Parameter1>en</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <!--  -->
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <CopyOutputSymbolsToPublishDirectory>false</CopyOutputSymbolsToPublishDirectory>
  </PropertyGroup>

  <PropertyGroup Condition="'$(PublishSingleFile)' == 'true'">
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>$(TFM_NET6_OR_LATER)</EnableCompressionInSingleFile>
  </PropertyGroup>

  <PropertyGroup Label="Nuget Properties">
    <_changelogPath>$([System.IO.Path]::GetFullPath($(MSBuildProjectDirectory)/../CHANGELOG.md))</_changelogPath>
    <Authors>HaloSPV3</Authors>
    <Copyright>Copyright © 2026 Noah Sherwin</Copyright>
    <Description>A HCE wrapper and SPV3 loader</Description>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeSource>true</IncludeSource>
    <IncludeSymbols>true</IncludeSymbols>
    <PackageIcon>icon.png</PackageIcon>
    <PackageIconUrl>https://github.com/HaloSPV3/HXE/blob/main/src/Assets/icon.png</PackageIconUrl>
    <PackageLicenseExpression>Zlib</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/HaloSPV3/HXE</PackageProjectUrl>
    <PackageReadmeFile>readme.md</PackageReadmeFile>
    <PackageReleaseNotes Condition="Exists($(_changelogPath))">$([System.IO.File]::ReadAllText($(_changelogPath)))</PackageReleaseNotes>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageTags>Halo</PackageTags>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/HaloSPV3/HXE</RepositoryUrl>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../.github/**/*.*">
      <Link>.github/%(RecursiveDir)%(Filename)%(Extension)</Link>
    </None>
    <None Include="../doc/**/*.*">
      <Link>.docs/%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include="../*.md">
      <Link>.docs-misc/%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include="*.txt">
      <Link>.docs-misc/%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include="src.licenseheader">
      <Link>.docs-misc/%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>

    <!-- Campaign Support -->
    <Content Include="Campaigns/*.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <TargetPath>%(FileName).xml</TargetPath>
    </Content>
    <!-- Assets -->
    <EmbeddedResource Include="../ext/halo-ce-patches/patches.crk">
      <Link>Assets/%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </EmbeddedResource>
    <EmbeddedResource Include="Assets/343I_DER.cer" />
    <Content Include="Assets/icon.ico" />
  </ItemGroup>

  <ItemGroup Label="NuGet Package Items">
    <None Include="Assets/icon.png" Pack="true" PackagePath="/" />
    <None Include="../readme.md" Pack="true" PackagePath="/">
      <Link>.docs-misc/readme.md</Link>
    </None>
  </ItemGroup>

  <ItemGroup Label="Package References">
    <PackageReference Include="GitVersion.MsBuild" Version="6.8.1">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Meziantou.Polyfill" Version="1.0.157">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="XmlSourceGenerator" Version="1.0.2-alpha" />
  </ItemGroup>

  <ItemGroup Label="Additional References (NET4)" Condition="$(TargetFramework.StartsWith('net4'))">
    <PackageReference Include="System.Net.Http" Version="4.3.4" />
    <PackageReference Include="Microsoft.Windows.CsWin32" Version="0.3.298">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="System.Memory" Version="4.6.3" />
    <PackageReference Include="System.Text.Json" Version="4.6.0" />

    <Reference Include="System.IO.Compression" Version="4.0.0.0" Culture="neutral" PublicKeyToken="b77a5c561934e089" />
  </ItemGroup>

  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="pwsh $(MSBuildProjectDirectory)/.msb.prebuild.ps1" />
  </Target>
</Project>
